# Email auth audit AI settings
# Supported providers: ollama, claude, openai, xai, gemini, openai-compatible, none
EMAIL_AUDIT_AI_PROVIDER=ollama
EMAIL_AUDIT_AI_MODEL=qwen3-coder-64k:latest
EMAIL_AUDIT_AI_TIMEOUT=90

# Optional global overrides
# EMAIL_AUDIT_AI_ENDPOINT=
# EMAIL_AUDIT_AI_API_KEY_ENV=

# Local Ollama
OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen3-coder-64k:latest

# Claude / Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1

# xAI / Grok
XAI_API_KEY=
XAI_MODEL=
XAI_BASE_URL=https://api.x.ai/v1

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models

# Generic OpenAI-compatible providers
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_BASE_URL=
